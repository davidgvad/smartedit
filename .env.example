# Models are loaded from the local Hugging Face cache by default. Review each
# checkpoint's size and license before changing this to 1.
SMARTEDIT_ALLOW_MODEL_DOWNLOADS=0

SMARTEDIT_DEVICE=auto
SMARTEDIT_QWEN_MODEL=Qwen/Qwen3-VL-4B-Instruct
SMARTEDIT_WHISPER_MODEL=openai/whisper-large-v3-turbo
SMARTEDIT_AUDIO_MODEL=nvidia/audio-flamingo-3-hf
SMARTEDIT_ENABLE_DEMUCS=0
SMARTEDIT_DEMUCS_MODEL=HDEMUCS_HIGH_MUSDB_PLUS
SMARTEDIT_CACHE_DIR=.smartedit-cache
SMARTEDIT_MAX_FRAMES=24
SMARTEDIT_DEBUG=0

# Add the official TransNetV2/inference-pytorch directory to PYTHONPATH.
# The checkpoint placeholder below is intentionally invalid.
SMARTEDIT_TRANSNET_CHECKPOINT=/absolute/path/to/transnetv2-pytorch-weights.pth
